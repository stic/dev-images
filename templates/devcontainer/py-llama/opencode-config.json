{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:6060/v1"
      },
      "models": {
        "local-llama": {
          "name": "Local Llama Model",
          "limit": {
            "context": 4096,
            "output": 1024
          }
        }
      }
    }
  }
}